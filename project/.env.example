# openOrbit Environment Configuration
#
# Copy this file to .env for local development.
# DO NOT commit .env to version control (it may contain secrets).

# Application version (semantic versioning)
VERSION=0.1.0

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Database connection string
# Format: sqlite+aiosqlite:///<path-to-db-file>
# For in-memory testing: sqlite+aiosqlite:///:memory:
DATABASE_URL=sqlite+aiosqlite:///./openorbit.db
