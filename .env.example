# openOrbit Environment Configuration
#
# Copy this file to .env for local development.
# DO NOT commit .env to version control (it may contain secrets).

# Application version (semantic versioning)
VERSION=0.1.0

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Database connection string
# Format: sqlite+aiosqlite:///<path-to-db-file>
# For in-memory testing: sqlite+aiosqlite:///:memory:
DATABASE_URL=sqlite+aiosqlite:///./openorbit.db

# Admin API key — required to use /v1/admin/* endpoints.
# Generate a strong random value, e.g.: openssl rand -hex 32
# Leave unset to disable admin endpoints entirely.
OPENORBIT_ADMIN_KEY=

# CORS allowed origins (comma-separated).
# Default "*" allows all origins (fine for dev / public read-only APIs).
# For production with credentialed requests, set to your frontend domain:
# CORS_ORIGINS=https://app.example.com,https://dashboard.example.com
CORS_ORIGINS=*

# Scraper behaviour
SCRAPER_DELAY_SECONDS=2
SCRAPER_TIMEOUT_SECONDS=30
SCRAPER_MAX_RETRIES=3
# Set to false in environments with corporate SSL inspection (e.g. Capgemini proxy)
SCRAPER_SSL_VERIFY=true

# Twitter/X API v2 Bearer token — required to enable the Twitter scraper.
# Obtain from https://developer.twitter.com/en/portal/dashboard
# Leave unset to disable the scraper gracefully (returns empty results).
TWITTER_BEARER_TOKEN=
